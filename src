labels = [
    "Calling", "Clapping", "Dancing", "Drinking", "Eating",
    "Fighting", "Hugging", "Laughing", "Listening to music",
    "Running", "Sitting", "Sleeping", "Texting",
    "Using laptop", "Cycling"
]

def get_label(index):
