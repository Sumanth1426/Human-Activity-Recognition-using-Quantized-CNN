import cv2
import numpy as np

def load_model(model_path):
    net = cv2.dnn.readNetFromONNX(model_path)
    return net

def predict(net, frame):
    net.setInput(frame)
    output = net.forward()
    class_id = np.argmax(output)
    confidence = float(np.max(output))
    return class_id, confidence

