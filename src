import cv2
import numpy as np

def preprocess_frame(frame):
    frame = cv2.resize(frame, (128, 128))
    frame = frame / 255.0
    frame = np.array(frame, dtype=np.float32)
    frame = np.expand_dims(frame, axis=0)
    return frame

